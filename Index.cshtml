@model PredictViewModel

@{
    ViewData["Title"] = "Disease Risk Predictor";

    // Risk colour helpers — only computed when a result exists
    var hasPrediction = Model.Probability.HasValue;
    var pct           = hasPrediction ? (int)(Model.Probability!.Value * 100) : 0;

    var (badgeBg, badgeText, barClass) = Model.RiskLevel switch
    {
        "Low"    => ("bg-success bg-opacity-10 text-success border border-success",
                     "text-success", "bg-success"),
        "Medium" => ("bg-warning bg-opacity-10 text-warning border border-warning",
                     "text-warning", "bg-warning"),
        "High"   => ("bg-danger  bg-opacity-10 text-danger  border border-danger",
                     "text-danger",  "bg-danger"),
        _        => ("", "", "bg-primary")
    };
}

<!-- ── Model Metrics Row ────────────────────────────────────────────── -->
<div class="row g-3 mb-4">
    <div class="col-4">
        <div class="card text-center py-3 shadow-sm">
            <div class="text-muted small"><b>ACCURACY</b></div>
            <div class="fs-4 fw-bold text-primary">@Model.ModelAccuracy.ToString("P2")</div>
        </div>
    </div>
    <div class="col-4">
        <div class="card text-center py-3 shadow-sm">
            <div class="text-muted small"><b>F1 SCORE</b></div>
            <div class="fs-4 fw-bold text-primary">@Model.ModelF1.ToString("F2")</div>
        </div>
    </div>
    <div class="col-4">
        <div class="card text-center py-3 shadow-sm">
            <div class="text-muted small"><b>AUC-ROC</b></div>
            <div class="fs-4 fw-bold text-primary">@Model.ModelAuc.ToString("F2")</div>
        </div>
    </div>
</div>

<!-- ── Main Layout ────────────────────────────────────────────────────── -->
<div class="row g-4">

    <!-- ── LEFT: Input Form ──────────────────────────────────────────── -->
    <div class="col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-white fw-semibold">
                PATIENT VITALS
            </div>
            <div class="card-body">

                <form method="post">

                    <div class="mb-3">
                        <label class="form-label fieldlabels">AGE</label>
                        <input asp-for="Age" type="number" class="form-control"
                               placeholder="e.g. 35" min="1" max="120" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fieldlabels">BMI</label>
                        <input asp-for="BMI" type="number" step="0.1" class="form-control"
                               placeholder="e.g. 27.5" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fieldlabels">GLUCOSE (mg/dL)</label>
                        <input asp-for="Glucose" type="number" class="form-control"
                               placeholder="e.g. 110" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fieldlabels">BLOOD PRESSURE (mmHg)</label>
                        <input asp-for="BloodPressure" type="number" class="form-control"
                               placeholder="e.g. 78" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fieldlabels">INSULIN (mu U/ml)</label>
                        <input asp-for="Insulin" type="number" class="form-control"
                               placeholder="e.g. 85" />
                    </div>

                    @* <div class="mb-3">
                        <label class="form-label">SkinThickness</label>
                        <input asp-for="SkinThickness" type="number" class="form-control"
                               placeholder="e.g. 35" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">DiabetesPedigreeFunction</label>
                        <input asp-for="DiabetesPedigreeFunction" type="number" class="form-control"
                               placeholder="e.g. 2.28" />
                    </div> *@

                    <div class="mb-3">
                        <label class="form-label fieldlabels">PREGNANCIES</label>
                        <input asp-for="Pregnancies" type="number" class="form-control"
                               placeholder="e.g. 2" min="0" />
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold">
                        PREDICT RISK
                    </button>

                </form>

            </div>
        </div>
    </div>

    <!-- ── RIGHT: Result Panel ───────────────────────────────────────── -->
    <div class="col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-white fw-semibold">
                PREDICTION RESULT
            </div>
            <div class="card-body d-flex flex-column justify-content-center align-items-center text-center gap-3">

                @if (!hasPrediction)
                {
                    <!-- Placeholder before any prediction -->
                    <div class="text-muted py-5">
                        <div style="font-size:3rem;">🩺</div>
                        <p class="mt-2 fieldlabels">Fill in the form and click <strong>Predict Risk</strong> to see the result.</p>
                    </div>
                }
                else
                {
                    <!-- Risk probability as big number -->
                    <div>
                        <div class="form-label fieldlabels">RISK PROBABILITY</div>
                        <div class="display-3 fw-bold @badgeText">@pct%</div>
                    </div>

                    <!-- Colour-coded progress bar -->
                    <div class="w-100 px-3">
                        <div class="progress" style="height: 14px; border-radius: 8px;">
                            <div class="progress-bar @barClass"
                                 style="width: @pct%; border-radius: 8px;"
                                 role="progressbar">
                            </div>
                        </div>
                        <div class="d-flex justify-content-between text-muted"
                             style="font-size: 15px; margin-top: 4px;">
                            <span>LOW</span><span>MEDIUM</span><span>HIGH</span>
                        </div>
                    </div>

                    <!-- Risk badge -->
                    <div class="px-4 py-2 rounded-pill fs-5 fw-semibold @badgeBg">
                        @Model.RiskLevel Risk
                    </div>

                    <!-- Plain language message -->
                    <p class="text-muted small px-3">
                        @(Model.RiskLevel switch {
                            "Low"    => "Low likelihood of diabetes based on the entered vitals.",
                            "Medium" => "Moderate risk detected. Consider consulting a physician.",
                            "High"   => "High risk detected. Please consult a doctor promptly.",
                            _        => ""
                        })
                    </p>
                }

            </div>
        </div>
    </div>

</div>


